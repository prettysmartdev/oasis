# Tailscale auth key — obtain from https://login.tailscale.com/admin/settings/keys
# Use a reusable, pre-authorized key for dev so the container reconnects after restarts.
# Copy this file to .env.local and fill in your values. Never commit .env.local.
TS_AUTHKEY=

# Management API port (default: 04515)
OASIS_MGMT_PORT=04515

# Tailscale node hostname — dashboard will be at https://<hostname>.<tailnet>.ts.net
OASIS_HOSTNAME=oasis

# SQLite database path inside container (default: /data/db/oasis.db)
OASIS_DB_PATH=/data/db/oasis.db

# Tailscale tsnet state directory inside container (default: /data/ts-state)
OASIS_TS_STATE_DIR=/data/ts-state

# Log verbosity: info | debug | warn | error (default: info)
OASIS_LOG_LEVEL=info

# Base URL for the controller tsnet API (leave empty to use same origin in production)
NEXT_PUBLIC_API_BASE_URL=

# Base directory for agent run work directories (default: /data/agent-runs)
OASIS_AGENT_RUNS_DIR=/data/agent-runs

# Claude CLI binary path (default: resolve "claude" from $PATH)
OASIS_CLAUDE_BIN=

# Timeout for synchronous chat invocations (default: 120s)
OASIS_CHAT_TIMEOUT=120s
